  <!-- ══════════════════════════════════════
       MOBILE ONLY — Sticky CTA Bar
  ══════════════════════════════════════ -->
  <div class="mobile-cta-bar" role="navigation" aria-label="Quick actions">
    <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="mobile-cta-bar__btn mobile-cta-bar__btn--call">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.33 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.49 5.49l1.92-1.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      Call Now
    </a>
    <a href="#contact" class="mobile-cta-bar__btn mobile-cta-bar__btn--book">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      Book Appointment
    </a>
  </div>

  <script is:inline>
    // Close Bootstrap navbar on mobile when a nav link is clicked
    document.querySelectorAll('#primaryNav .nav-link, #primaryNav .nav-cta').forEach(function(link) {
      link.addEventListener('click', function() {
        var collapseEl = document.getElementById('primaryNav');
        var bsCollapse = bootstrap.Collapse.getInstance(collapseEl);
        if (bsCollapse) bsCollapse.hide();
      });
    });

    // Dynamic year in footer
    document.getElementById('year').textContent = new Date().getFullYear();

    // Contact form submission feedback
    document.getElementById('appointmentForm').addEventListener('submit', function(e) {
      e.preventDefault();
      if (!this.checkValidity()) {
        this.reportValidity();
        return;
      }
      var btn = this.querySelector('.form-submit');
      btn.textContent = 'Message Sent ✓';
      btn.disabled = true;
      btn.style.backgroundColor = 'var(--color-accent)';
    });

    // Mascot
    var mascot        = document.getElementById('mascot');
    var mascotDismiss = document.getElementById('mascotDismiss');
    var mascotBody    = mascot && mascot.querySelector('.mascot__body');

    if (mascot) {
      mascot.addEventListener('click', function(e) {
        if (e.target === mascotDismiss || mascotDismiss.contains(e.target)) return;
        mascot.classList.toggle('bubble-open');
      });
    }

    if (mascotDismiss) {
      mascotDismiss.addEventListener('click', function(e) {
        e.stopPropagation();
        mascot.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
        mascot.style.opacity = '0';
        mascot.style.transform = 'translateY(80px) scale(0.5)';
        setTimeout(function() { mascot.remove(); }, 420);
      });
    }

    if (mascotBody) {
      mascot.addEventListener('mouseleave', function() {
        mascotBody.style.animation = 'none';
        void mascotBody.offsetWidth;
        mascotBody.style.animation = '';
      });
    }

    // Hide navbar on scroll down, show on scroll up
    var siteHeader = document.querySelector('.site-header');
    var lastScrollY = window.scrollY;
    window.addEventListener('scroll', function() {
      var currentScrollY = window.scrollY;
      if (currentScrollY > lastScrollY && currentScrollY > 72) {
        siteHeader.classList.add('nav-hidden');
      } else {
        siteHeader.classList.remove('nav-hidden');
      }
      lastScrollY = currentScrollY;
    }, { passive: true });

    // Scroll Reveal
    var revealEls = [].concat(
      Array.from(document.querySelectorAll('.service-card')),
      Array.from(document.querySelectorAll('.testimonial-card')),
      Array.from(document.querySelectorAll('.gallery__item')),
      Array.from(document.querySelectorAll('.section-header')),
      Array.from(document.querySelectorAll('.about__inner')),
      Array.from(document.querySelectorAll('.contact__inner')),
      Array.from(document.querySelectorAll('.stats-bar')),
      Array.from(document.querySelectorAll('.mobile-quick-info__card'))
    );
    revealEls.forEach(function(el) { el.classList.add('reveal'); });

    var revealIO = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('reveal--visible');
          revealIO.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    revealEls.forEach(function(el) { revealIO.observe(el); });

    // Scroll Spy
    var spySections = document.querySelectorAll('main section[id]');
    var spyLinks    = document.querySelectorAll('.site-navbar .primary-nav__link');

    var spyIO = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          spyLinks.forEach(function(l) { l.classList.remove('active'); l.removeAttribute('aria-current'); });
          var active = document.querySelector('.site-navbar a[href="#' + entry.target.id + '"]');
          if (active) { active.classList.add('active'); active.setAttribute('aria-current', 'page'); }
        }
      });
    }, { rootMargin: '-50% 0px -50% 0px' });
    spySections.forEach(function(s) { spyIO.observe(s); });
  </script>

</Layout>
