---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const home = await getEntry('pages', 'home');
const { meta, hero, services, about, testimonials, stats, gallery, contact, footer } = home.data;

const serviceIconPaths: Record<string, string> = {
  tooth: `<path d="M24 6C17 6 11 12 11 19c0 4 1.5 7.5 3.5 10.5L17 38c.5 2.5 1.5 4 3.5 4s3-1.5 2.5-4.5l-.5-3c-.3-1.5.5-2.5 1.5-2.5s1.8 1 1.5 2.5l-.5 3C24.5 40.5 25.5 42 27.5 42s3-1.5 3.5-4l2.5-8.5C35.5 26.5 37 23 37 19c0-7-6-13-13-13z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/>`,
  smile: `<circle cx="24" cy="24" r="16" stroke="currentColor" stroke-width="2.2"/><path d="M16 28s3-5 8-5 8 5 8 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/><circle cx="18" cy="21" r="2" fill="currentColor"/><circle cx="30" cy="21" r="2" fill="currentColor"/>`,
  implant: `<rect x="12" y="14" width="24" height="20" rx="4" stroke="currentColor" stroke-width="2.2"/><path d="M18 14v-2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="2.2"/><path d="M24 22v4M22 24h4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>`,
  braces: `<path d="M10 32c0-8 4-16 14-16s14 8 14 16" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/><path d="M16 32h16M13 36h22" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>`,
  veneer: `<path d="M14 20h20v14a4 4 0 0 1-4 4H18a4 4 0 0 1-4-4V20z" stroke="currentColor" stroke-width="2.2"/><path d="M10 20h28" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/><path d="M20 20v-4a4 4 0 0 1 8 0v4" stroke="currentColor" stroke-width="2.2"/>`,
  rootcanal: `<path d="M24 10v4M24 34v4M10 24h4M34 24h4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/><circle cx="24" cy="24" r="10" stroke="currentColor" stroke-width="2.2"/><circle cx="24" cy="24" r="4" fill="currentColor" opacity=".25"/>`,
};
---

<Layout title={meta.title} description={meta.description}>

  <!-- ══════════════════════════════════════
       HEADER / NAV
  ══════════════════════════════════════ -->
  <header class="site-header" id="top">
    <nav class="navbar navbar-expand-lg site-navbar" role="navigation" aria-label="Primary">
      <div class="container">

        <a href="#home" class="navbar-brand site-header__logo" aria-label="Dr. Yousef Abu Koush – Home">
          <svg class="logo-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20 4C14 4 8 9 8 15c0 3.5 1.5 6.5 3 9l2 8c.5 2 1.5 4 4 4s3.5-2 3-5l-.5-3.5c-.3-2 .8-3.5 0-3.5s.3 1.5 0 3.5L19 33c-.5 3 .5 5 3 5s3.5-2 4-4l2-8c1.5-2.5 3-5.5 3-9 0-6-6-11-12-11z" fill="currentColor"/>
          </svg>
          <span class="logo-text">
            <span class="logo-text__name">Dr. Yousef Abu Koush</span>
            <span class="logo-text__sub">Dental Clinic</span>
          </span>
        </a>

        <button class="navbar-toggler site-nav-toggler" type="button"
          data-bs-toggle="collapse" data-bs-target="#primaryNav"
          aria-controls="primaryNav" aria-expanded="false" aria-label="Toggle navigation">
          <span></span><span></span><span></span>
        </button>

        <div class="collapse navbar-collapse" id="primaryNav">
          <ul class="navbar-nav ms-auto align-items-lg-center">
            <li class="nav-item"><a href="#home"         class="nav-link primary-nav__link">Home</a></li>
            <li class="nav-item"><a href="#services"     class="nav-link primary-nav__link">Services</a></li>
            <li class="nav-item"><a href="#about"        class="nav-link primary-nav__link">About</a></li>
            <li class="nav-item"><a href="#testimonials" class="nav-link primary-nav__link">Testimonials</a></li>
            <li class="nav-item"><a href="#contact"      class="nav-link primary-nav__link">Contact</a></li>
          </ul>
          <a href="#contact" class="btn btn--primary nav-cta ms-lg-3">Book Appointment</a>
        </div>

      </div>
    </nav>
  </header>

  <main>

    <!-- ══════════════════════════════════════
         SECTION 1 — HERO
    ══════════════════════════════════════ -->
    <section class="hero" id="home">
      <div class="hero__overlay" aria-hidden="true"></div>
      <img
        class="hero__bg"
        src={hero.bg_image}
        alt="Modern dental clinic interior — bright, clean and welcoming"
        loading="eager"
        fetchpriority="high"
      />
      <div class="container hero__content">
        <p class="hero__eyebrow">{hero.eyebrow}</p>
        <h1 class="hero__title">{hero.title}<br />{hero.title_sub}</h1>
        <p class="hero__lead">{hero.lead}</p>
        <div class="hero__actions">
          <a href="#contact" class="btn btn--primary">{hero.cta_primary_text}</a>
          <a href="#services" class="btn btn--outline">{hero.cta_secondary_text}</a>
        </div>
        <ul class="hero__trust">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            {hero.trust_items[0].text}
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            {hero.trust_items[1].text}
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {hero.trust_items[2].text}
          </li>
        </ul>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         MOBILE ONLY — QUICK INFO STRIP
    ══════════════════════════════════════ -->
    <section class="mobile-quick-info" aria-label="Why choose us" id="mobileQuickInfo">
      <div class="container">
        <h2 class="mobile-quick-info__title">Why Dr. Yousef?</h2>
        <div class="mobile-quick-info__cards">
          <div class="mobile-quick-info__card">
            <svg class="mobile-quick-info__icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M24 6C17 6 11 12 11 19c0 4 1.5 7.5 3.5 10.5L17 38c.5 2.5 1.5 4 3.5 4s3-1.5 2.5-4.5l-.5-3c-.3-1.5.5-2.5 1.5-2.5s1.8 1 1.5 2.5l-.5 3C24.5 40.5 25.5 42 27.5 42s3-1.5 3.5-4l2.5-8.5C35.5 26.5 37 23 37 19c0-7-6-13-13-13z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/>
            </svg>
            <span><strong>20+ Years</strong> of Expert Dental Care</span>
          </div>
          <div class="mobile-quick-info__card">
            <svg class="mobile-quick-info__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span><strong>3,500+</strong> Happy Patients Treated</span>
          </div>
          <div class="mobile-quick-info__card">
            <svg class="mobile-quick-info__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span><strong>Certified &amp; Insured</strong> — Pain-Free Guarantee</span>
          </div>
        </div>
        <a href="#contact" class="btn mobile-quick-info__cta">Book Your Appointment &rarr;</a>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         SECTION 2 — SERVICES
    ══════════════════════════════════════ -->
    <section class="services section section--alt" id="services">
      <div class="container">
        <div class="section-header">
          <span class="section-header__eyebrow">{services.eyebrow}</span>
          <h2 class="section-header__title">{services.title}</h2>
          <div class="divider"></div>
          <p class="section-header__subtitle">{services.subtitle}</p>
        </div>

        <ul class="services__grid">
          {services.items.map((service: { icon: string; title: string; description: string }) => (
            <li class="service-card">
              <div class="service-card__icon" aria-hidden="true">
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" set:html={serviceIconPaths[service.icon] ?? ''} />
              </div>
              <h3 class="service-card__title">{service.title}</h3>
              <p class="service-card__text">{service.description}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         SECTION 3 — ABOUT
    ══════════════════════════════════════ -->
    <section class="about section" id="about">
      <div class="container about__inner">

        <div class="about__image-wrap">
          <img
            src={about.photo}
            alt={about.photo_alt}
            class="about__photo"
          />
          <div class="about__badge">
            <span class="about__badge-number">{about.experience_years}</span>
            <span class="about__badge-label">Years of<br />Experience</span>
          </div>
        </div>

        <div class="about__body">
          <span class="section-header__eyebrow">{about.eyebrow}</span>
          <h2 class="about__title">{about.name}</h2>
          <div class="divider" style="margin: 0.75rem 0 1.25rem;"></div>

          <p class="about__text">{about.bio1}</p>
          <p class="about__text">{about.bio2}</p>

          <ul class="about__highlights">
            {about.highlights.map((highlight: string) => (
              <li>
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {highlight}
              </li>
            ))}
          </ul>

          <a href="#contact" class="btn btn--primary about__cta">{about.cta_text}</a>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════
         SECTION 4 — TESTIMONIALS
    ══════════════════════════════════════ -->
    <section class="testimonials section section--alt" id="testimonials">
      <div class="container">
        <div class="section-header">
          <span class="section-header__eyebrow">{testimonials.eyebrow}</span>
          <h2 class="section-header__title">{testimonials.title}</h2>
          <div class="divider"></div>
          <p class="section-header__subtitle">{testimonials.subtitle}</p>
        </div>

        <ul class="testimonials__grid">
          {testimonials.items.map((t: { name: string; treatment: string; quote: string; avatar: string }) => (
            <li class="testimonial-card">
              <div class="testimonial-card__stars" aria-label="5 out of 5 stars">
                <span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
              </div>
              <blockquote class="testimonial-card__quote">
                &ldquo;{t.quote}&rdquo;
              </blockquote>
              <div class="testimonial-card__author">
                <img
                  src={t.avatar}
                  alt={`Portrait of ${t.name}`}
                  class="testimonial-card__avatar"
                />
                <div>
                  <strong>{t.name}</strong>
                  <span>{t.treatment}</span>
                </div>
              </div>
            </li>
          ))}
        </ul>

        <!-- Stats bar -->
        <ul class="stats-bar">
          {stats.map((stat: { number: string; label: string }) => (
            <li class="stats-bar__item">
              <span class="stats-bar__number">{stat.number}</span>
              <span class="stats-bar__label">{stat.label}</span>
            </li>
          ))}
        </ul>

      </div>
    </section>

    <!-- ══════════════════════════════════════
         SECTION 5 — GALLERY
    ══════════════════════════════════════ -->
    <section class="gallery section" id="gallery">
      <div class="container">
        <div class="section-header">
          <span class="section-header__eyebrow">{gallery.eyebrow}</span>
          <h2 class="section-header__title">{gallery.title}</h2>
          <div class="divider"></div>
          <p class="section-header__subtitle">{gallery.subtitle}</p>
        </div>

        <div class="gallery__grid">

          <figure class="gallery__item gallery__item--tall">
            <img
              src="https://images.unsplash.com/photo-1584467735815-f778f274e296?w=800&q=80&auto=format&fit=crop"
              alt="Dentist examining a patient in a modern dental chair"
              loading="lazy"
            />
            <figcaption>Gentle, attentive care</figcaption>
          </figure>

          <figure class="gallery__item">
            <img
              src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?w=800&q=80&auto=format&fit=crop"
              alt="Modern dental clinic reception area"
              loading="lazy"
            />
            <figcaption>Welcoming reception</figcaption>
          </figure>

          <figure class="gallery__item">
            <img
              src="https://images.unsplash.com/photo-1609840114035-3c981b782dfe?w=800&q=80&auto=format&fit=crop"
              alt="State-of-the-art dental equipment"
              loading="lazy"
            />
            <figcaption>State-of-the-art equipment</figcaption>
          </figure>

          <figure class="gallery__item gallery__item--wide">
            <img
              src="https://images.unsplash.com/photo-1598256989800-fe5f95da9787?w=1200&q=80&auto=format&fit=crop"
              alt="Patient smiling with perfect white teeth after treatment"
              loading="lazy"
            />
            <figcaption>Real smile results</figcaption>
          </figure>

          <figure class="gallery__item">
            <img
              src="https://images.unsplash.com/photo-1571772996211-2f02c9727629?w=800&q=80&auto=format&fit=crop"
              alt="Dentist discussing treatment plan with patient"
              loading="lazy"
            />
            <figcaption>Clear communication, every visit</figcaption>
          </figure>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         SECTION 6 — CONTACT
    ══════════════════════════════════════ -->
    <section class="contact section section--alt" id="contact">
      <div class="container contact__inner">

        <div class="contact__info">
          <span class="section-header__eyebrow">{contact.eyebrow}</span>
          <h2 class="contact__title">{contact.title}</h2>
          <div class="divider" style="margin: 0.75rem 0 1.5rem;"></div>
          <p class="contact__lead">{contact.lead}</p>

          <ul class="contact__details">
            <li>
              <div class="contact__details-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <strong>Address</strong>
                <span>{contact.address}</span>
              </div>
            </li>
            <li>
              <div class="contact__details-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.33 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.49 5.49l1.92-1.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <div>
                <strong>Phone</strong>
                <span>{contact.phone}</span>
              </div>
            </li>
            <li>
              <div class="contact__details-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <strong>Email</strong>
                <span>{contact.email}</span>
              </div>
            </li>
            <li>
              <div class="contact__details-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div>
                <strong>Opening Hours</strong>
                <span>{contact.hours_weekday}</span>
                <span>{contact.hours_weekend}</span>
              </div>
            </li>
          </ul>
        </div>

        <div class="contact__form-wrap">
          <form class="contact__form" id="appointmentForm" novalidate>
            <div class="form-row row g-2">
              <div class="form-group col-12 col-sm-6">
                <label class="form-label" for="fname">First Name <span aria-hidden="true">*</span></label>
                <input type="text" class="form-control" id="fname" name="fname" placeholder="Yousef" required />
              </div>
              <div class="form-group col-12 col-sm-6">
                <label class="form-label" for="lname">Last Name <span aria-hidden="true">*</span></label>
                <input type="text" class="form-control" id="lname" name="lname" placeholder="Abu Koush" required />
              </div>
            </div>

            <div class="form-row row g-2">
              <div class="form-group col-12 col-sm-6">
                <label class="form-label" for="email">Email Address <span aria-hidden="true">*</span></label>
                <input type="email" class="form-control" id="email" name="email" placeholder="you@example.com" required />
              </div>
              <div class="form-group col-12 col-sm-6">
                <label class="form-label" for="phone">Phone Number</label>
                <input type="tel" class="form-control" id="phone" name="phone" placeholder="+962 7X XXX XXXX" />
              </div>
            </div>

            <div class="form-group col-12">
              <label class="form-label" for="service">Service Interested In <span aria-hidden="true">*</span></label>
              <select class="form-select" id="service" name="service" required>
                <option value="" disabled selected>Select a service&hellip;</option>
                {services.items.map((s: { title: string }) => (
                  <option>{s.title}</option>
                ))}
                <option>Other</option>
              </select>
            </div>

            <div class="form-group col-12">
              <label class="form-label" for="message">Message / Preferred Date</label>
              <textarea class="form-control" id="message" name="message" rows="4" placeholder="Tell us about your concern or a preferred appointment date&hellip;"></textarea>
            </div>

            <button type="submit" class="btn btn--primary form-submit">Send Request</button>

            <p class="form-note">We respect your privacy. Your information is never shared.</p>
          </form>
        </div>

      </div>
    </section>

  </main>

  <!-- ══════════════════════════════════════
       FOOTER
  ══════════════════════════════════════ -->
  <footer class="site-footer">
    <div class="container site-footer__inner">

      <div class="site-footer__brand">
        <a href="#top" class="site-header__logo site-footer__logo" aria-label="Back to top">
          <svg class="logo-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20 4C14 4 8 9 8 15c0 3.5 1.5 6.5 3 9l2 8c.5 2 1.5 4 4 4s3.5-2 3-5l-.5-3.5c-.3-2 .8-3.5 0-3.5s.3 1.5 0 3.5L19 33c-.5 3 .5 5 3 5s3.5-2 4-4l2-8c1.5-2.5 3-5.5 3-9 0-6-6-11-12-11z" fill="currentColor"/>
          </svg>
          <span class="logo-text">
            <span class="logo-text__name">Dr. Yousef Abu Koush</span>
            <span class="logo-text__sub">Dental Clinic</span>
          </span>
        </a>
        <p class="site-footer__tagline">{footer.tagline}</p>
      </div>

      <nav class="site-footer__nav" aria-label="Footer navigation">
        <h3 class="site-footer__nav-heading">Quick Links</h3>
        <ul>
          <li><a href="#home">Home</a></li>
          <li><a href="#services">Services</a></li>
          <li><a href="#about">About Dr. Yousef</a></li>
          <li><a href="#testimonials">Testimonials</a></li>
          <li><a href="#gallery">Gallery</a></li>
          <li><a href="#contact">Book Appointment</a></li>
        </ul>
      </nav>

      <div class="site-footer__contact">
        <h3 class="site-footer__nav-heading">Contact</h3>
        <address>
          <p>{contact.address}</p>
          <p><a href={`tel:${contact.phone.replace(/\s/g, '')}`}>{contact.phone}</a></p>
          <p><a href={`mailto:${contact.email}`}>{contact.email}</a></p>
        </address>
        <p class="site-footer__hours">{contact.hours_weekday} &nbsp;|&nbsp; {contact.hours_weekend}</p>
      </div>

    </div>

    <div class="site-footer__bottom">
      <div class="container">
        <p>&copy; <span id="year"></span> Dr. Yousef Abu Koush Dental Clinic. All rights reserved.</p>
        <p>Built with Astro &amp; Bootstrap 5 &mdash; designed with care.</p>
      </div>
    </div>
  </footer>

  <!-- ══════════════════════════════════════
       MASCOT — Sparky the Tooth
  ══════════════════════════════════════ -->
  <div class="mascot" id="mascot" aria-label="Dental mascot Sparky the Tooth">
    <div class="mascot__bubble" role="tooltip" id="mascotBubble">
      <p class="mascot__bubble-greeting">👋 Hi, I'm <strong>Sparky</strong>!</p>
      <p class="mascot__bubble-msg">Ready for a brighter, healthier smile? Our friendly team is here for you every step of the way!</p>
      <a href="#contact" class="mascot__bubble-cta">Book Free Consultation &rarr;</a>
    </div>
    <button class="mascot__dismiss" id="mascotDismiss" aria-label="Dismiss mascot" title="Dismiss">&times;</button>
    <div class="mascot__body" aria-hidden="true">
      <svg class="mascot__svg" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g class="mascot__arm mascot__arm--left">
